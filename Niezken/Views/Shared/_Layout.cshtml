<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Seaphaerys - @ViewData["Title"]</title>

    <link rel="icon" href="~/favicons.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background: #f5fbff;
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: #03396c;
            margin: 0;
        }

        header {
            background: #e3f2fd;
        }

        .navbar {
            padding: 8px 20px; 
        }

        .navbar-brand img {
            height: 38px;
        }

        .nav-link {
            color: #03396c !important;
            font-weight: 600;
            margin: 24px; 
            font-size: 0.95rem;
            position: relative;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        /* Underline animation on hover */
        .nav-link::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: -4px;
            width: 0;
            height: 3px;
            background: #0077b6;
            transition: .3s;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        /* Active page link — underline stays visible */
        .active-link::after {
            width: 100% !important;
        }

        /* Login button (shown when not logged in) — pill shaped */
        .login-btn {
            background: #0077b6;
            color: white;
            border-radius: 25px;
            padding: 7px 20px;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: 0.3s;
        }

        .login-btn:hover {
            background: #023e8a;
            color: white;
        }

        /* Book Now — now a plain nav link, no more orange bubble */
        .booknow-link {
            color: #0077b6 !important;
            font-weight: 700;
        }

        .booknow-link::after {
            background: #0077b6 !important;
        }

        /* User dropdown button — looks like a pill with avatar icon */
        .user-dropdown-btn {
            background: #0077b6;
            color: white !important;
            border: none;
            border-radius: 25px;
            padding: 7px 16px;
            font-size: 0.88rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            /* Remove the underline animation inherited from .nav-link */
        }

        .user-dropdown-btn::after {
            display: none !important; /* Hide the underline pseudo-element */
        }

        .user-dropdown-btn:hover {
            background: #023e8a;
            color: white !important;
        }

        /* Dropdown menu styling */
        .user-dropdown-menu {
            border: none;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
            padding: 8px 0;
            min-width: 190px;
        }

        .user-dropdown-menu .dropdown-item {
            padding: 9px 18px;
            font-size: 0.9rem;
            font-weight: 500;
            color: #03396c;
            transition: 0.2s;
        }

        .user-dropdown-menu .dropdown-item:hover {
            background: #f0f8ff;
            color: #0077b6;
        }

        /* Divider line inside the dropdown */
        .user-dropdown-menu .dropdown-divider {
            margin: 4px 0;
            border-color: #e0f0ff;
        }

        /* Logout item in red */
        .user-dropdown-menu .dropdown-item.logout-item {
            color: #e63946;
        }

        .user-dropdown-menu .dropdown-item.logout-item:hover {
            background: #fff0f1;
            color: #c1121f;
        }

        .content-wrapper {
            flex: 1;
        }

        /* Wave decoration under the navbar */
        .ocean {
            position: relative;
            width: 100%;
            background: #e3f2fd;
            line-height: 0;
        }

        .wave-svg {
            width: 100%;
            height: 80px;
        }

        /* Footer styles */
        .footer-dark {
            padding: 20px;
            color: #f0f9ff;
            background-color: #282d32;
        }

            .footer-dark h3 {
                margin-top: 0;
                margin-bottom: 12px;
                font-weight: bold;
                font-size: 16px;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: #fff;
            }

            .footer-dark ul {
                padding: 0;
                list-style: none;
                line-height: 1.6;
                font-size: 14px;
                margin-bottom: 0;
            }

                .footer-dark ul a {
                    color: inherit;
                    text-decoration: none;
                    opacity: 0.6;
                }

                    .footer-dark ul a:hover {
                        opacity: 0.8;
                    }

            .footer-dark .item.text p {
                opacity: 0.6;
                margin-bottom: 0;
            }

            .footer-dark .item.social {
                text-align: center;
                margin-top: 20px;
            }

                .footer-dark .item.social > a {
                    font-size: 18px;
                    width: 40px;
                    height: 40px;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 50%;
                    box-shadow: 0 0 0 1px rgba(255,255,255,0.4);
                    margin: 0 8px;
                    color: #fff;
                    opacity: 0.75;
                    transition: 0.3s;
                    text-decoration: none;
                }

                    .footer-dark .item.social > a:hover {
                        opacity: 0.9;
                        box-shadow: 0 0 0 1px rgba(255,255,255,1);
                        transform: translateY(-3px);
                    }

            .footer-dark .copyright {
                text-align: center;
                padding-top: 24px;
                opacity: 0.3;
                font-size: 13px;
                margin-bottom: 0;
            }
    </style>
</head>

<body>

    @{
        // Get the current action name so we can highlight the active nav link
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <header>

        <nav class="navbar navbar-expand-lg">

            <div class="container">

                @* Logo — clicking it goes to the Home page *@
                <a class="navbar-brand" asp-controller="Home" asp-action="Index" id="log">
                    <img src="~/image/LOG.png" alt="Seaphaerys Logo">
                </a>

                @* Mobile hamburger button (for small screens) *@
                <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbar">

                    @* LEFT SIDE: Navigation Links *@
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "Index" ? "active-link" : "")"
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "Accommodation" ? "active-link" : "")"
                               asp-controller="Home" asp-action="Accommodation">Accommodation</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "Outlets" ? "active-link" : "")"
                               asp-controller="Home" asp-action="Outlets">Outlets</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "Contact" ? "active-link" : "")"
                               asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "faq" ? "active-link" : "")"
                               asp-controller="Home" asp-action="faq">FAQs</a>
                        </li>

                        @* Book Now is ALWAYS visible — logged in or not.
                           If not logged in, clicking it will redirect to login
                           (handled by [Authorize] in BookingController) *@
                        <li class="nav-item">
                            <a class="nav-link booknow-link @(currentAction == "BookNow" ? "active-link" : "")"
                               asp-controller="Booking" asp-action="BookNow">Book Now</a>
                        </li>

                        @* Admin gets an extra "Admin Panel" nav link *@
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentAction == "AdminDashboard" ? "active-link" : "")"
                                   asp-controller="Admin" asp-action="AdminDashboard">Admin Panel</a>
                            </li>
                        }

                    </ul>

                    @* RIGHT SIDE: Login button OR user dropdown *@
                    <div class="d-flex align-items-center">

                        @if (User.Identity.IsAuthenticated)
                        {
                            @* DROPDOWN — shows username as the toggle button *@
                            <div class="dropdown">

                                @* Toggle button — shows just the name before @ *@
                                <a class="user-dropdown-btn dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    @User.Identity.Name?.Split('@')[0]
                                </a>

                                @* Dropdown menu *@
                                <ul class="dropdown-menu dropdown-menu-end user-dropdown-menu">

                                    @* Full email shown at top — info only, not clickable *@
                                    <li>
                                        <span class="dropdown-item-text text-muted small px-3 py-1">
                                            @User.Identity.Name
                                        </span>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Admin" asp-action="MyAccount">My Account</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Admin" asp-action="AdminDashboard">Admin Dashboard</a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="User" asp-action="Dashboard">My Dashboard</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="User" asp-action="EditProfile">Edit Profile</a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <a class="dropdown-item logout-item"
                                           asp-controller="Home" asp-action="Logout">Logout</a>
                                    </li>

                                </ul>
                            </div>
                        }
                        else
                        {
                            @* Not logged in — show Login button only *@
                            <a asp-controller="Home" asp-action="Login" class="login-btn">Login</a>
                        }

                    </div>

                </div>

            </div>

        </nav>

        @* Decorative wave below the navbar *@
        <div class="ocean">
            <svg class="wave-svg" viewBox="0 0 1440 120" preserveAspectRatio="none">
                <path fill="#f5fbff" fill-opacity="1"
                      d="M0,32L60,42.7C120,53,240,75,360,80C480,85,600,75,720,58.7C840,43,960,21,1080,21.3C1200,21,1320,43,1380,53.3L1440,64L1440,120L1380,120C1320,120,1200,120,1080,120C960,120,840,120,720,120C600,120,480,120,360,120C240,120,120,120,60,120L0,120Z">
                </path>
            </svg>
        </div>

    </header>

    @* MAIN CONTENT: each page's content is injected here *@
    <div class="content-wrapper">
        <main class="container pb-5">
            @RenderBody()
        </main>
    </div>

    @* FOOTER *@
    <footer class="footer-dark">
        <div class="container">
            <div class="row">
                <div class="col-sm-6 col-md-3 item">
                    <h3>Services</h3>
                    <ul>
                        <li><a asp-controller="Booking" asp-action="BookNow">Ticket Booking</a></li>
                        <li><a href="#">Ferry Schedule</a></li>
                        <li><a asp-controller="Home" asp-action="Accommodation">Accommodation</a></li>
                    </ul>
                </div>
                <div class="col-sm-6 col-md-3 item">
                    <h3>About</h3>
                    <ul>
                        <li><a href="#">Company</a></li>
                        <li><a href="#">Team</a></li>
                        <li><a href="#">Careers</a></li>
                    </ul>
                </div>
                <div class="col-md-6 item text">
                    <h3>Seaphaerys</h3>
                    <p>Connecting the Philippine islands through safe, reliable, and comfortable sea travel.</p>
                </div>
                <div class="col item social">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-snapchat"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
            <p class="copyright">Niezken Sea Ferry © 2026</p>
        </div>
    </footer>

    @* Bootstrap JS (needed for the hamburger menu, modals, etc.) *@
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @* Each page can inject its own scripts here using @section Scripts *@
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
