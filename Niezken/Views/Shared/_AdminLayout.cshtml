<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Seaphaerys Admin - @ViewData["Title"]</title>

    <link rel="icon" href="~/favicons.ico" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background: #f5fbff;
            font-family: 'Segoe UI',sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: #03396c;
            margin: 0;
        }

        header {
            background: #e3f2fd;
        }

        .navbar {
            padding: 12px 20px;
        }

        .navbar-brand img {
            height: 50px;
        }

        .nav-link {
            color: #03396c !important;
            font-weight: 600;
            margin-right: 25px;
            position: relative;
        }

            .nav-link::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -6px;
                width: 0;
                height: 3px;
                background: #0077b6;
                transition: .3s;
            }

            .nav-link:hover::after {
                width: 100%;
            }

        .active-link::after {
            width: 100%;
        }

        .logout-btn {
            background: #0077b6;
            color: white;
            border-radius: 25px;
            padding: 8px 22px;
            font-weight: 600;
            text-decoration: none;
        }

            .logout-btn:hover {
                background: #023e8a;
                color: white;
            }

        .content-wrapper {
            flex: 1;
        }
       /*  wavy */
        .ocean {
            position: relative;
            width: 100%;
            background: #e3f2fd;
            line-height: 0;
        }

        .wave-svg {
            width: 100%;
            height: 80px;
        }

        /* footer*/
        .footer-dark {
            padding: 20px;
            color: #f0f9ff;
            background-color: #282d32;
        }

            .footer-dark h3 {
                margin-top: 0;
                margin-bottom: 12px;
                font-weight: bold;
                font-size: 16px;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: #fff;
            }

            .footer-dark ul {
                padding: 0;
                list-style: none;
                line-height: 1.6;
                font-size: 14px;
                margin-bottom: 0;
            }

                .footer-dark ul a {
                    color: inherit;
                    text-decoration: none;
                    opacity: 0.6;
                }

                    .footer-dark ul a:hover {
                        opacity: 0.8;
                    }

            .footer-dark .item.text {
                margin-bottom: 36px;
            }

                .footer-dark .item.text p {
                    opacity: 0.6;
                    margin-bottom: 0;
                }

            .footer-dark .item.social {
                text-align: center;
                margin-top: 20px;
            }

                .footer-dark .item.social > a {
                    font-size: 18px;
                    width: 40px;
                    height: 40px;
                    /* Use flexbox to center the icon perfectly inside the circle */
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 50%;
                    box-shadow: 0 0 0 1px rgba(255,255,255,0.4);
                    margin: 0 8px;
                    color: #fff;
                    opacity: 0.75;
                    transition: 0.3s;
                    text-decoration: none; /* Removes underline if any */
                }

                    .footer-dark .item.social > a:hover {
                        opacity: 0.9;
                        box-shadow: 0 0 0 1px rgba(255,255,255,1);
                        transform: translateY(-3px);
                    }

            .footer-dark .copyright {
                text-align: center;
                padding-top: 24px;
                opacity: 0.3;
                font-size: 13px;
                margin-bottom: 0;
            }

        .nav-link {
            position: relative;
        }

            .nav-link::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -5px;
                width: 0%;
                height: 3px;
                background-color: #0077b6;
                transition: width 0.3s ease;
            }

            .nav-link:hover::after {
                width: 100%;
            }

        .active-link::after {
            width: 100%;
        }
    </style>
</head>

<body>

    @{
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">

                <a class="navbar-brand" asp-controller="Admin" asp-action="AdminDashboard">
                    <img src="~/image/LOG.png">
                </a>

                <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbar">

                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "AdminDashboard" ? "active-link" : "")"
                               asp-controller="Admin"
                               asp-action="AdminDashboard">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "Users" ? "active-link" : "")"
                               asp-controller="Admin"
                               asp-action="Users">
                                Users
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "ActivityLogs" ? "active-link" : "")"
                               asp-controller="Admin"
                               asp-action="ActivityLogs">
                                Activity Logs
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "Accommodation" ? "active-link" : "")"
                               asp-controller="Admin"
                               asp-action="Accommodation">
                                Accommodations
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "MyAccount" ? "active-link" : "")"
                               asp-controller="Admin"
                               asp-action="MyAccount">
                                My Account
                            </a>
                        </li>
                    </ul>

                    <div>
                        <span class="me-3 fw-semibold">
                            @User.Identity.Name
                        </span>

                        <a asp-controller="Home"
                           asp-action="Logout"
                           class="logout-btn">
                            Logout
                        </a>
                    </div>

                </div>
            </div>
        </nav>
        <div class="ocean">
            <svg class="wave-svg" viewBox="0 0 1440 120" preserveAspectRatio="none">
                <path fill="#f5fbff" fill-opacity="1"
                      d="M0,32L60,42.7C120,53,240,75,360,80C480,85,600,75,720,58.7C840,43,960,21,1080,21.3C1200,21,1320,43,1380,53.3L1440,64L1440,120L1380,120C1320,120,1200,120,1080,120C960,120,840,120,720,120C600,120,480,120,360,120C240,120,120,120,60,120L0,120Z">
                </path>
            </svg>
        </div>
    </header>
    <div class="content-wrapper">
        <main class="container pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-dark">
        <div class="container">
            <div class="row">
                <div class="col-sm-6 col-md-3 item">
                    <h3>Services</h3>
                    <ul>
                        <li><a href="#">Ticket Booking</a></li>
                        <li><a href="#">Ferry Schedule</a></li>
                        <li><a href="#">Accommodation</a></li>
                    </ul>
                </div>
                <div class="col-sm-6 col-md-3 item">
                    <h3>About</h3>
                    <ul>
                        <li><a href="#">Company</a></li>
                        <li><a href="#">Team</a></li>
                        <li><a href="#">Careers</a></li>
                    </ul>
                </div>
                <div class="col-md-6 item text">
                    <h3>Seaphaerys</h3>
                    <p>Praesent sed lobortis mi. Suspendisse vel plo.</p>
                </div>
                <div class="col item social">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-snapchat"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
            <p class="copyright">Niezken Sea Ferry © 2026</p>
        </div>
    </footer>
    <script src="~/js/site.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>