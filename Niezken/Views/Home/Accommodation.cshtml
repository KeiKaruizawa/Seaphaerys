@{
    ViewData["Title"] = "Accommodation";
}

<div class="container mt-5">

    <!-- Title -->
    <div class="text-center mb-4">
        <h2 class="fw-bold text-pink">Meet The Fleet</h2>
        <p class="text-muted">
            Prices may vary among our vessels depending on your destination
        </p>
    </div>

    <!-- Fleet Grid -->
    <div class="row g-4">

        <!-- Ship 1 -->
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card ship-card shadow-sm">
                <img src="~/image/ship1.jpg"
                     class="card-img-top ship-img"
                     alt="Ship 1">
                <div class="card-body text-center">
                    <h6 id="vessel" class="fw-bold">MV St. Nicholas</h6>
                    <a asp-controller="Home"
                       asp-action="AccommodationDetails"
                       asp-route-id="1"
                       class="btn btn-sm btn-pink mt-2"
                       id="view">
                        View Details
                    </a>
                </div>
            </div>
        </div>

        <!-- Ship 2 -->
