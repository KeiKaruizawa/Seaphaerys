@model Niezken.Models.ShipViewModel
@{
    ViewData["Title"] = "Ship Details";
}

<div class="container mt-5">
    <div class="row">

        <!-- Ship Image -->
        <div class="col-md-6">
            <img src="~/image/@Model.Image" class="img-fluid rounded shadow" alt="@Model.Name" />
        </div>

        <!-- Ship Details -->
        <div class="col-md-6">
            <h2 class="fw-bold text-pink">@Model.Name</h2>
            <hr />

            <p><strong>Route:</strong> @Model.Route</p>
            <p><strong>Starting Price:</strong> @Model.Price</p>

            <h5 class="mt-3">Description</h5>
            <p>@Model.Description</p>

            <h5 class="mt-3">Amenities</h5>
            <ul>
                <li>Air-conditioned cabins</li>
                <li>Restaurant & Lounge</li>
                <li>WiFi Access</li>
                <li>Comfort Rooms</li>
                <li>Safety Equipment</li>
            </ul>

            <a asp-controller="Home" asp-action="Accommodation" class="btn btn-secondary mt-3" id="backfleet">
                Back to Fleet
            </a>
        </div>

    </div>
</div>