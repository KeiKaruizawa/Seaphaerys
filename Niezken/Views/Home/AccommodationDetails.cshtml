@model Niezken.Models.ShipViewModel
@{
    ViewData["Title"] = "Ship Details";
}

<div class="container mt-5">
    <div class="row">

        <!-- LEFT SIDE - IMAGE SLIDER -->
        <div class="col-md-6">

            <div id="shipCarousel" class="carousel slide shadow rounded" data-bs-ride="carousel">

                <div class="carousel-inner rounded">

                    <!-- Room Image -->
                    <div class="carousel-item active">
                        <img src="@Url.Content("~/image/room" + Model.Id + ".jfif")"
                             class="d-block w-100 detail-img"
                             alt="Room">
                        <div class="carousel-caption bg-opacity-50 rounded" id="bcolor">
                            <h6>Cabin Room</h6>
                        </div>
                    </div>

                    <!-- Balcony Image -->
                    <div class="carousel-item">
                        <img src="@Url.Content("~/image/bal" + Model.Id + ".jfif")"
                             class="d-block w-100 detail-img"
                             alt="Balcony">
                        <div class="carousel-caption  bg-opacity-50 rounded" id="bcolor">
                            <h6>Balcony View</h6>
                        </div>
                    </div>

                    <!-- Inside Image -->
                    <div class="carousel-item">
                       <img src="@Url.Content("~/image/in" + Model.Id + ".jfif")"
                            class="d-block w-100 detail-img"
                            alt="Interior">
                        <div class="carousel-caption bg-opacity-50 rounded" id="bcolor">
                            <h6>Interior Amenities</h6>
                        </div>
                    </div>

                </div>

                <!-- Controls -->
                <button class="carousel-control-prev" type="button"
                        data-bs-target="#shipCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next" type="button"
                        data-bs-target="#shipCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

            </div>

        </div>

        <!-- RIGHT SIDE - SHIP DETAILS -->
        <div class="col-md-6">

            <h2 class="fw-bold text-pink">@Model.Name</h2>
            <hr />

            <p><strong>Route:</strong> @Model.Route</p>
            <p><strong>Starting Price:</strong> @Model.Price</p>

            <h5 class="mt-3">About This Cruise</h5>
            <p>@Model.Description</p>

            <h5 class="mt-3">Cruise Features</h5>
            <ul>
                <li>Air-conditioned Cabins</li>
                <li>Private Balcony Rooms Available</li>
                <li>Entertainment Lounge</li>
                <li>Restaurant & Dining Area</li>
                <li>Free WiFi in Public Areas</li>
                <li>24/7 Security & Safety Equipment</li>
            </ul>

            <a asp-controller="Home"
               asp-action="Accommodation"
               class="btn btn-secondary mt-3" id="backfleet">
                Back to Fleet
            </a>

            <a asp-controller="Booking"
               asp-action="Create"
               asp-route-id="@Model.Id"
               asp-route-name="@Model.Name"
               asp-route-route="@Model.Route"
               asp-route-price="@Model.Price"
               class="btn btn-success mt-3">
                Book Now
            </a>
        </div>
    </div>
</div>
