@{
    ViewData["Title"] = "Home Page";
}

<style>
    /* Hero Carousel Adjustments */
    .carousel-item {
        height: 60vh;
        min-height: 400px;
        background: #03396c;
    }

    .carousel-caption {
        background: rgba(0, 0, 0, 0.5);
        border-radius: 15px;
        padding: 20px;
        bottom: 20%;
    }

    .carousel-item img {
        object-fit: cover;
        height: 100%;
        width: 100%;
        opacity: 0.8;
    }

    /* Section Headers */
    .section-title {
        color: #0077b6;
        font-weight: 700;
        margin-top: 50px;
        margin-bottom: 30px;
        position: relative;
        display: inline-block;
    }

        .section-title::after {
            content: '';
            width: 50%;
            height: 3px;
            background: #ffd166;
            position: absolute;
            bottom: -10px;
            left: 25%;
        }

    /* Accommodation Cards */
    .feature-card {
        border: none;
        transition: 0.3s;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .card-img-top {
        height: 200px;
        object-fit: cover;
    }
</style>

<div id="vesselCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#vesselCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#vesselCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#vesselCarousel" data-bs-slide-to="2"></button>
    </div>
    <div class="carousel-inner shadow-lg">
        <div class="carousel-item active">
            <img src="~/image/homeship.jpg" class="d-block w-100" alt="Fast Craft">
            <div class="carousel-caption d-none d-md-block">
                <h2>Elite Fast Craft</h2>
                <p>Reach your destination in record time with our high-speed jet ferries.</p>
                <a href="#" class="btn btn-warning">View Schedule</a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/image/roro.jpg" class="d-block w-100" alt="RoRo Vessel">
            <div class="carousel-caption d-none d-md-block">
                <h2>Ro-Ro Cargo Vessels</h2>
                <p>Bringing your vehicles and heavy cargo safely across the sea.</p>
                <a href="#" class="btn btn-warning">Cargo Rates</a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/image/other.jpg" class="d-block w-100" alt="Luxury Liner">
            <div class="carousel-caption d-none d-md-block">
                <h2>Night Liners</h2>
                <p>Enjoy a comfortable overnight stay while sailing to the islands.</p>
                <a href="#" class="btn btn-warning">Book Cabin</a>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#vesselCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#vesselCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="container text-center mb-5">
    <h2 class="section-title">Premium Accommodations</h2>

    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card feature-card h-100">
                <img src="https://images.unsplash.com/photo-1517089596392-db215233441b?auto=format&fit=crop&w=500&q=60" class="card-img-top" alt="Economy">
                <div class="card-body">
                    <h5 class="card-title">Economy Class</h5>
                    <p class="card-text text-muted">Open-air seating with refreshing sea breezes. Best for short trips.</p>
                    <p class="fw-bold text-primary">Starts at $15.00</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card feature-card h-100">
                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=500&q=60" class="card-img-top" alt="Tourist">
                <div class="card-body">
                    <h5 class="card-title">Tourist Class</h5>
                    <p class="card-text text-muted">Fully air-conditioned cabins with comfortable reclining seats and entertainment.</p>
                    <p class="fw-bold text-primary">Starts at $25.00</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card feature-card h-100">
                <img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&w=500&q=60" class="card-img-top" alt="Suite">
                <div class="card-body">
                    <h5 class="card-title">VIP Suite</h5>
                    <p class="card-text text-muted">Private cabins with en-suite bathrooms, TV, and premium meal service.</p>
                    <p class="fw-bold text-primary">Starts at $75.00</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-white py-5 shadow-sm rounded-4 mb-5">
    <div class="row text-center px-4">
        <div class="col-md-4 border-end">
            <i class="fas fa-shield-alt fa-3x text-info mb-3"></i>
            <h4>Safety First</h4>
            <p class="text-muted">International safety standards and trained crew.</p>
        </div>
        <div class="col-md-4 border-end">
            <i class="fas fa-clock fa-3x text-info mb-3"></i>
            <h4>On-Time Departure</h4>
            <p class="text-muted">98% punctuality rate across all sea routes.</p>
        </div>
        <div class="col-md-4">
            <i class="fas fa-anchor fa-3x text-info mb-3"></i>
            <h4>Island Coverage</h4>
            <p class="text-muted">Connecting over 25 major ports nationwide.</p>
        </div>
    </div>
</div>