@model Niezken.Models.BookSearchViewModel

@{
    ViewData["Title"] = "Book Now";
    Layout = "_Layout";
    var ports = ViewBag.Ports as List<string> ?? new List<string>();
    // "from" tells BookingForm if user came from the Accommodation page
    var fromParam = ViewBag.From as string ?? "";
}

<style>
    .page-title {
        color: #0077b6;
        font-weight: 700;
        margin-top: 40px;
        margin-bottom: 5px;
    }

    .search-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.07);
        margin-bottom: 40px;
    }

    .form-label {
        font-weight: 600;
        color: #03396c;
        margin-bottom: 6px;
    }

    .form-select, .form-control {
        border: 1.5px solid #d0e8f5;
        border-radius: 10px;
        padding: 10px 14px;
        color: #03396c;
    }

        .form-select:focus, .form-control:focus {
            border-color: #0077b6;
            box-shadow: 0 0 0 3px rgba(0,119,182,0.1);
        }

        /* Red border on invalid fields after submit attempt */
        .form-select.is-invalid, .form-control.is-invalid {
            border-color: #dc3545 !important;
        }

    .btn-search {
        background-color: #03396c;
        color: white;
        border: 1.5px solid #03396c;
        border-radius: 10px;
        padding: 11px 35px;
        font-weight: 700;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-search:hover {
            background-color: white;
            color: #03396c;
        }

    .results-title {
        color: #03396c;
        font-weight: 700;
        margin-bottom: 20px;
        font-size: 1rem;
    }

    .ship-result-card {
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.07);
        background: white;
        border: none;
        height: 100%;
    }

        .ship-result-card:hover {
            transform: scale(1.03);
        }

    .ship-result-img {
        height: 180px;
        object-fit: cover;
        width: 100%;
    }

    .ship-result-name {
        font-weight: 700;
        color: #03396c;
        font-size: 1rem;
        margin-bottom: 4px;
    }

    .ship-result-price {
        color: #0077b6;
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 12px;
    }

    .btn-select {
        background-color: #03396c;
        color: white;
        border: 1.5px solid #03396c;
        border-radius: 8px;
        padding: 7px 0;
        font-weight: 600;
        width: 100%;
        display: block;
        text-align: center;
        text-decoration: none;
        transition: 0.3s;
        font-size: 0.9rem;
    }

        .btn-select:hover {
            background-color: white;
            color: #03396c;
        }

    .no-results {
        text-align: center;
        padding: 50px 20px;
        color: #888;
        background: white;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .swap-btn {
        background: #e3f2fd;
        border: none;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        color: #0077b6;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

        .swap-btn:hover {
            background: #0077b6;
            color: white;
        }

    /* Error text — shown under each field individually */
    .field-error {
        color: #dc3545;
        font-size: 0.82rem;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="mt-2">

    <h2 class="page-title">Book Your Ferry</h2>
    <p class="text-muted mb-4">Search available vessels for your route and travel date.</p>

    <div class="search-card">
        <form asp-action="BookNow" method="post">

            <div class="row align-items-start g-3">

                @* Origin dropdown — error shown inline below the field *@
                <div class="col-md-4">
                    <label class="form-label">From</label>
                    <select asp-for="Origin"
                            class="form-select @(ViewData.ModelState["Origin"]?.Errors.Count > 0 ? "is-invalid" : "")">
                        <option value="">-- Select Origin --</option>
                        @foreach (var port in ports)
                        {
                            <option value="@port" selected="@(Model.Origin == port)">@port</option>
                        }
                    </select>
                    @* Validation error shown directly under the field *@
                    <span asp-validation-for="Origin" class="field-error"></span>
                </div>

                @* Swap button *@
                <div class="col-auto d-none d-md-flex justify-content-center">
                    <button type="button" class="swap-btn" onclick="swapPorts()" title="Swap">⇄</button>
                </div>

                @* Destination dropdown *@
                <div class="col-md-4">
                    <label class="form-label">To</label>
                    <select asp-for="Destination"
                            class="form-select @(ViewData.ModelState["Destination"]?.Errors.Count > 0 ? "is-invalid" : "")">
                        <option value="">-- Select Destination --</option>
                        @foreach (var port in ports)
                        {
                            <option value="@port" selected="@(Model.Destination == port)">@port</option>
                        }
                    </select>
                    <span asp-validation-for="Destination" class="field-error"></span>
                </div>

                @* Travel date *@
                <div class="col-md-3">
                    <label class="form-label">Travel Date</label>
                    <input asp-for="TravelDate"
                           type="date"
                           class="form-control @(ViewData.ModelState["TravelDate"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="TravelDate" class="field-error"></span>
                </div>

            </div>

            @* General errors (e.g. same origin and destination) shown inline, no big box *@
            @if (!ViewData.ModelState.IsValid)
            {
                @foreach (var error in ViewData.ModelState[""]?.Errors ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.ModelBinding.ModelError>())
                {
                    <p class="field-error mt-2">@error.ErrorMessage</p>
                }
            }

            <div class="mt-4">
                <button type="submit" class="btn-search">Search Vessels</button>
            </div>

        </form>
    </div>

    @* Search results — only shown after form is submitted *@
    @if (Model.AvailableShips != null)
    {
        <hr style="border-color: #d0e8f5;" />

        @if (!Model.AvailableShips.Any())
        {
            <div class="no-results">
                <p class="fw-bold mb-1">No vessels found for this route.</p>
                <p class="text-muted small mb-0">Try a different origin or destination.</p>
            </div>
        }
        else
        {
            <p class="results-title mt-4">
                @Model.AvailableShips.Count vessel(s) found —
                @Model.Origin to @Model.Destination on
                @Model.TravelDate.ToString("MMMM dd, yyyy")
            </p>

            <div class="row g-4">
                @foreach (var ship in Model.AvailableShips)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="ship-result-card">
                            <img src="~/image/@ship.Image"
                                 class="ship-result-img"
                                 alt="@ship.Name"
                                 onerror="this.src='https://images.unsplash.com/photo-1516495312540-a148643b22d3?w=400'" />
                            <div class="p-3">
                                <div class="ship-result-name">@ship.Name</div>
                                <div class="text-muted small mb-1">@ship.Route</div>
                                <div class="ship-result-price">
                                    @Html.Raw(ship.Price)
                                    <span class="text-muted fw-normal small">/ person</span>
                                </div>
                                @* Show departure time for this route direction *@
                                @if (!string.IsNullOrEmpty(ship.DepartureTime))
                                {
                                    <div class="text-muted small mb-2">
                                        Departs: <strong style="color:#03396c;">@ship.DepartureTime</strong>
                                    </div>
                                }
                                @* Clicking goes to BookingForm — [Authorize] redirects to Login if not logged in *@
                                @* Pass fromParam so BookingForm knows to show back button *@
                                <a asp-controller="Booking"
                                   asp-action="BookingForm"
                                   asp-route-shipId="@ship.Id"
                                   asp-route-route="@ship.Route"
                                   asp-route-price="@ship.Price"
                                   asp-route-travelDate="@Model.TravelDate.ToString("yyyy-MM-dd")"
                                   asp-route-from="@fromParam"
                                   class="btn-select">
                                    Select This Vessel
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function swapPorts() {
            const origin = document.querySelector('[name="Origin"]');
            const dest = document.querySelector('[name="Destination"]');
            const temp = origin.value;
            origin.value = dest.value;
            dest.value = temp;
        }
    </script>
}
