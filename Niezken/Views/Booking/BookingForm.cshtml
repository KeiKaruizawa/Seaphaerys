@model Niezken.Models.BookingFormViewModel

@{
    ViewData["Title"] = "Booking Details";
    Layout = "_Layout";

    @* Images are named room1-8, bal1-8, in1-8
       RouteId on ship goes 1-8 (each original vessel = one RouteId)
       We use RouteId to pick the right image *@
    var imageId = Model.ShipId;

    var fromParam = ViewBag.From as string ?? "";
    var cameFromAccommodation = fromParam == "accommodation";
}

<style>
    .trip-summary {
        background-color: #03396c;
        color: white;
        border-radius: 15px;
        padding: 20px 28px;
        margin-top: 30px;
        margin-bottom: 30px;
    }

        .trip-summary h5 {
            font-weight: 700;
            margin-bottom: 8px;
        }

        .trip-summary .badge-info {
            background: rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 4px 14px;
            font-size: 0.85rem;
            display: inline-block;
            margin-right: 8px;
            margin-top: 4px;
        }

    .section-card {
        background: white;
        border-radius: 15px;
        padding: 28px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.07);
        margin-bottom: 24px;
    }

        .section-card h5 {
            color: #03396c;
            font-weight: 700;
            border-bottom: 2px solid #e3f2fd;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

    .form-label {
        font-weight: 600;
        color: #03396c;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        border: 1.5px solid #d0e8f5;
        border-radius: 10px;
        padding: 10px 14px;
        color: #03396c;
    }

        .form-control:focus, .form-select:focus {
            border-color: #0077b6;
            box-shadow: 0 0 0 3px rgba(0,119,182,0.1);
        }

        /* Red border for invalid fields — shown by JS, not server */
        .form-control.error, .form-select.error {
            border-color: #dc3545 !important;
        }

    /* Error text under each field */
    .field-error {
        color: #dc3545;
        font-size: 0.82rem;
        margin-top: 4px;
        display: none; /* Hidden by default, shown by JS when needed */
    }

        .field-error.visible {
            display: block;
        }

    /* Accommodation image cards */
    .acc-option {
        border: 2px solid #d0e8f5;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        transition: 0.25s;
        background: white;
        height: 100%;
    }

        .acc-option:hover {
            border-color: #0077b6;
            transform: translateY(-3px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        }

        .acc-option.selected {
            border-color: #03396c;
            box-shadow: 0 0 0 3px rgba(3,57,108,0.2);
        }

        /* Red border on accommodation if not selected and user tried to submit */
        .acc-option.error-border {
            border-color: #dc3545 !important;
        }

    .acc-img {
        width: 100%;
        height: 140px;
        object-fit: cover;
        display: block;
    }

    .acc-body {
        padding: 10px 14px 12px;
    }

        .acc-body strong {
            display: block;
            color: #03396c;
            font-weight: 700;
            font-size: 0.95rem;
        }

        .acc-body small {
            color: #888;
            font-size: 0.8rem;
        }

    .acc-check {
        display: none;
        color: white;
        background: #03396c;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 2px 10px;
        border-radius: 20px;
        margin-top: 5px;
        width: fit-content;
    }

    .acc-option.selected .acc-check {
        display: block;
    }

    /* Payment method radio cards */
    .payment-option {
        border: 2px solid #d0e8f5;
        border-radius: 12px;
        padding: 14px 18px;
        cursor: pointer;
        transition: 0.2s;
        display: flex;
        align-items: center;
        gap: 12px;
        background: white;
    }

        .payment-option:hover {
            border-color: #0077b6;
            background: #f0f8ff;
        }

        .payment-option.selected {
            border-color: #03396c;
            background: #e3f2fd;
        }

        .payment-option input[type="radio"] {
            accent-color: #03396c;
            width: 16px;
            height: 16px;
        }

        .payment-option .pay-label {
            font-weight: 600;
            color: #03396c;
            font-size: 0.9rem;
        }

        .payment-option .pay-note {
            font-size: 0.78rem;
            color: #888;
        }

    /* Passenger blocks */
    .passenger-block {
        border: 1.5px solid #d0e8f5;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
        background: #f8fbff;
        position: relative;
    }

    .passenger-tag {
        position: absolute;
        top: -12px;
        left: 18px;
        background: #03396c;
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 2px 14px;
        border-radius: 20px;
    }

    /* Review & Pay button */
    .btn-review {
        background-color: #03396c;
        color: white;
        border: 1.5px solid #03396c;
        border-radius: 10px;
        padding: 12px 0;
        font-weight: 700;
        width: 100%;
        font-size: 1rem;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-review:hover {
            background-color: white;
            color: #03396c;
        }

    .back-link {
        color: #03396c;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.9rem;
        display: block;
        text-align: center;
        margin-top: 12px;
    }

        .back-link:hover {
            color: #0077b6;
            text-decoration: underline;
        }

    /* Review modal rows */
    .review-row {
        display: flex;
        justify-content: space-between;
        padding: 7px 0;
        border-bottom: 1px solid #f0f8ff;
        font-size: 0.9rem;
    }

        .review-row:last-child {
            border-bottom: none;
        }

        .review-row .r-label {
            color: #888;
        }

        .review-row .r-value {
            font-weight: 600;
            color: #03396c;
        }

    /* Confirm button inside the modal */
    .btn-confirm-final {
        background-color: #03396c;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 11px 30px;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-confirm-final:hover {
            background: #0077b6;
            color: white;
        }
</style>

@* ---- TRIP SUMMARY BAR ---- *@
<div class="trip-summary">
    <h5>@Model.ShipName</h5>
    <span class="badge-info">@Model.Route</span>
    <span class="badge-info">@Model.TravelDate.ToString("MMMM dd, yyyy")</span>
    <span class="badge-info">@Html.Raw(Model.Price) / person</span>
    @if (!string.IsNullOrEmpty(Model.DepartureTime))
    {
        <span class="badge-info">Departs: @Model.DepartureTime</span>
    }
</div>

@* The actual form — only submitted after JS validation passes *@
<form asp-action="BookingForm" method="post" id="bookingForm">

    @* Hidden fields carry ship data *@
    <input type="hidden" asp-for="ShipId" />
    <input type="hidden" asp-for="ShipName" />
    <input type="hidden" asp-for="Route" />
    <input type="hidden" asp-for="Price" />
    <input type="hidden" asp-for="TravelDate" />
    <input type="hidden" asp-for="DepartureTime" />

    @* ============================================================
       SECTION 1: Accommodation Type
       Images use RouteId (1-8) matching the original ship images
       ============================================================ *@
    <div class="section-card">
        <h5>Select Accommodation Type</h5>

        <div class="row g-3">

            @* Cabin — uses room{id}.jfif *@
            <div class="col-md-4">
                <div class="acc-option" id="acc-cabin" onclick="selectAccommodation(this, 'Cabin')">
                    <img src="~/image/room@(imageId).jfif"
                         class="acc-img" alt="Cabin"
                         onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=400'" />
                    <div class="acc-body">
                        <strong>Cabin</strong>
                        <small>Standard air-conditioned room</small>
                        <span class="acc-check">&#10003; Selected</span>
                    </div>
                </div>
            </div>

            @* Balcony — uses bal{id}.jfif *@
            <div class="col-md-4">
                <div class="acc-option" id="acc-balcony" onclick="selectAccommodation(this, 'Balcony')">
                    <img src="~/image/bal@(imageId).jfif"
                         class="acc-img" alt="Balcony"
                         onerror="this.src='https://images.unsplash.com/photo-1566665797739-1674de7a421a?w=400'" />
                    <div class="acc-body">
                        <strong>Balcony</strong>
                        <small>Private ocean view balcony</small>
                        <span class="acc-check">&#10003; Selected</span>
                    </div>
                </div>
            </div>

            @* Suite — uses in{id}.jfif *@
            <div class="col-md-4">
                <div class="acc-option" id="acc-suite" onclick="selectAccommodation(this, 'Suite')">
                    <img src="~/image/in@(imageId).jfif"
                         class="acc-img" alt="Suite"
                         onerror="this.src='https://images.unsplash.com/photo-1582719508461-905c673771fd?w=400'" />
                    <div class="acc-body">
                        <strong>Suite</strong>
                        <small>Premium room with meal service</small>
                        <span class="acc-check">&#10003; Selected</span>
                    </div>
                </div>
            </div>

        </div>

        <input type="hidden" asp-for="AccommodationType" id="accommodationInput" />
        @* Error shown if user clicks Review without selecting accommodation *@
        <span class="field-error" id="accError">Please select an accommodation type.</span>
    </div>

    @* ============================================================
       SECTION 2: Contact Info & Passenger Count
       ============================================================ *@
    <div class="section-card">
        <h5>Contact Information</h5>

        <div class="row g-3">

            <div class="col-md-6">
                <label class="form-label">Contact Number</label>
                <input asp-for="ContactNumber"
                       id="contactNumber"
                       class="form-control"
                       placeholder="e.g. 09171234567"
                       maxlength="15" />
                @* Error shown inline without form reset *@
                <span class="field-error" id="contactError">Please enter a contact number.</span>
            </div>

            <div class="col-md-3">
                <label class="form-label">Number of Passengers</label>
                <input asp-for="PassengerCount"
                       type="number"
                       class="form-control"
                       min="1" max="20"
                       id="passengerCountInput"
                       onchange="updatePassengerForms()" />
                <span class="field-error" id="passengerCountError">Must be at least 1.</span>
            </div>

        </div>
    </div>

    @* ============================================================
       SECTION 3: Passenger Details
       ============================================================ *@
    <div class="section-card">
        <h5>Passenger Details</h5>

        <div id="passengerForms">
            <div class="passenger-block" data-index="0">
                <span class="passenger-tag">Passenger 1</span>
                <div class="row g-3 mt-1">
                    <div class="col-md-5">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="Passengers[0].FullName" id="pax0Name"
                               class="form-control" placeholder="e.g. Juan Dela Cruz" />
                        <span class="field-error" id="pax0NameError">Full name is required.</span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Age</label>
                        <input type="number" name="Passengers[0].Age" id="pax0Age"
                               class="form-control" min="1" max="120" placeholder="Age" />
                        <span class="field-error" id="pax0AgeError">Valid age required.</span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Sex</label>
                        <select name="Passengers[0].Sex" id="pax0Sex" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span class="field-error" id="pax0SexError">Please select sex.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ============================================================
       SECTION 4: Payment Method
       No real gateway — just records how they intend to pay
       ============================================================ *@
    <div class="section-card">
        <h5>Payment Method</h5>
        <p class="text-muted small mb-3">Select your preferred online payment method. Details will be sent after booking.</p>

        <div class="row g-3">

            @* GCash *@
            <div class="col-md-6">
                <div class="payment-option" onclick="selectPayment(this, 'GCash')">
                    <input type="radio" name="_paymentDisplay" value="GCash" />
                    <div>
                        <div class="pay-label">GCash</div>
                        <div class="pay-note">Send payment via GCash before travel date</div>
                    </div>
                </div>
            </div>

            @* PayMaya *@
            <div class="col-md-6">
                <div class="payment-option" onclick="selectPayment(this, 'PayMaya')">
                    <input type="radio" name="_paymentDisplay" value="PayMaya" />
                    <div>
                        <div class="pay-label">PayMaya</div>
                        <div class="pay-note">Send payment via PayMaya before travel date</div>
                    </div>
                </div>
            </div>

        </div>

        @* Hidden input stores the selected payment method for form submission *@
        <input type="hidden" asp-for="PaymentMethod" id="paymentInput" />
        <span class="field-error" id="paymentError">Please select a payment method.</span>
    </div>

    @* Review & Pay button — triggers JS validation then opens review modal *@
    <div class="mb-5">
        <button type="button" class="btn-review" onclick="validateAndReview()">
            Review &amp; Confirm
        </button>

        @* Back to Fleet — only shown if user came from Accommodation page.
           If user came directly from navbar Book Now, no back button is shown. *@
        @if (cameFromAccommodation)
        {
            <a asp-controller="Home" asp-action="Accommodation"
               class="back-link">
                Back to Fleet
            </a>
        }
    </div>

</form>

@* ============================================================
   REVIEW MODAL
   Shows a full summary of the booking before final submission.
   Only opens after all fields are validated.
   ============================================================ *@
<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius:15px;">

            <div class="modal-header" style="border-bottom:2px solid #e3f2fd;">
                <h5 class="modal-title fw-bold" style="color:#03396c;">Review Your Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body px-4">

                <p class="text-muted small mb-3">
                    Please review your booking details before confirming.
                </p>

                @* Trip details *@
                <div style="background:#f8fbff; border-radius:10px; padding:16px; margin-bottom:16px;">
                    <div class="review-row">
                        <span class="r-label">Ship</span>
                        <span class="r-value">@Model.ShipName</span>
                    </div>
                    <div class="review-row">
                        <span class="r-label">Route</span>
                        <span class="r-value">@Model.Route</span>
                    </div>
                    <div class="review-row">
                        <span class="r-label">Travel Date</span>
                        <span class="r-value">@Model.TravelDate.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <div class="review-row">
                        <span class="r-label">Accommodation</span>
                        <span class="r-value" id="reviewAccommodation">—</span>
                    </div>
                    <div class="review-row">
                        <span class="r-label">Base Price</span>
                        <span class="r-value">@Html.Raw(Model.Price) / person</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.DepartureTime))
                    {
                        <div class="review-row">
                            <span class="r-label">Departure Time</span>
                            <span class="r-value">@Model.DepartureTime</span>
                        </div>
                    }
                </div>

                @* Contact & payment *@
                <div style="background:#f8fbff; border-radius:10px; padding:16px; margin-bottom:16px;">
                    <div class="review-row">
                        <span class="r-label">Contact Number</span>
                        <span class="r-value" id="reviewContact">—</span>
                    </div>
                    <div class="review-row">
                        <span class="r-label">Total Passengers</span>
                        <span class="r-value" id="reviewPaxCount">—</span>
                    </div>
                    <div class="review-row">
                        <span class="r-label">Payment Method</span>
                        <span class="r-value" id="reviewPayment">—</span>
                    </div>
                </div>

                @* Passenger list — filled dynamically by JS *@
                <div id="reviewPassengerList"
                     style="background:#f8fbff; border-radius:10px; padding:16px;">
                </div>

            </div>

            <div class="modal-footer" style="border-top:2px solid #e3f2fd;">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal"
                        style="border-radius:8px;">
                    Go Back & Edit
                </button>
                @* This button submits the actual form after review *@
                <button type="button" class="btn-confirm-final"
                        onclick="document.getElementById('bookingForm').submit()">
                    Confirm & Book
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>

        // ---- Accommodation selection ----
        function selectAccommodation(el, value) {
            document.querySelectorAll('.acc-option').forEach(o => {
                o.classList.remove('selected', 'error-border');
            });
            el.classList.add('selected');
            document.getElementById('accommodationInput').value = value;
            document.getElementById('accError').classList.remove('visible');
        }

        // ---- Payment selection ----
        function selectPayment(el, value) {
            document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('selected'));
            el.classList.add('selected');
            // Check the radio inside
            el.querySelector('input[type="radio"]').checked = true;
            document.getElementById('paymentInput').value = value;
            document.getElementById('paymentError').classList.remove('visible');
        }

        // ---- Passenger blocks: add/remove based on count ----
        function updatePassengerForms() {
            const count = parseInt(document.getElementById('passengerCountInput').value) || 1;
            const container = document.getElementById('passengerForms');
            const existing = container.querySelectorAll('.passenger-block').length;

            if (count > existing) {
                for (let i = existing; i < count; i++) {
                    const block = document.createElement('div');
                    block.className = 'passenger-block';
                    block.setAttribute('data-index', i);
                    block.innerHTML = `
                        <span class="passenger-tag">Passenger ${i + 1}</span>
                        <div class="row g-3 mt-1">
                            <div class="col-md-5">
                                <label class="form-label">Full Name</label>
                                <input type="text" name="Passengers[${i}].FullName" id="pax${i}Name"
                                       class="form-control" placeholder="e.g. Juan Dela Cruz" />
                                <span class="field-error" id="pax${i}NameError">Full name is required.</span>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Age</label>
                                <input type="number" name="Passengers[${i}].Age" id="pax${i}Age"
                                       class="form-control" min="1" max="120" placeholder="Age" />
                                <span class="field-error" id="pax${i}AgeError">Valid age required.</span>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Sex</label>
                                <select name="Passengers[${i}].Sex" id="pax${i}Sex" class="form-select">
                                    <option value="">-- Select --</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                                <span class="field-error" id="pax${i}SexError">Please select sex.</span>
                            </div>
                        </div>`;
                    container.appendChild(block);
                }
            } else {
                const blocks = container.querySelectorAll('.passenger-block');
                for (let i = existing - 1; i >= count; i--) {
                    blocks[i].remove();
                }
            }
        }

        // ---- Main validation function ----
        // Checks all fields WITHOUT submitting the form.
        // If valid, opens the review modal.
        // If invalid, shows errors inline next to each field.
        function validateAndReview() {
            let valid = true;

            // 1. Accommodation
            const accVal = document.getElementById('accommodationInput').value;
            if (!accVal) {
                document.getElementById('accError').classList.add('visible');
                document.querySelectorAll('.acc-option').forEach(o => o.classList.add('error-border'));
                valid = false;
            }

            // 2. Contact number
            const contact = document.getElementById('contactNumber');
            if (!contact.value.trim()) {
                contact.classList.add('error');
                document.getElementById('contactError').classList.add('visible');
                valid = false;
            } else {
                contact.classList.remove('error');
                document.getElementById('contactError').classList.remove('visible');
            }

            // 3. Passenger count
            const paxCount = document.getElementById('passengerCountInput');
            if (!paxCount.value || parseInt(paxCount.value) < 1) {
                paxCount.classList.add('error');
                document.getElementById('passengerCountError').classList.add('visible');
                valid = false;
            } else {
                paxCount.classList.remove('error');
                document.getElementById('passengerCountError').classList.remove('visible');
            }

            // 4. Each passenger's fields
            const count = parseInt(paxCount.value) || 1;
            for (let i = 0; i < count; i++) {
                const nameEl  = document.getElementById(`pax${i}Name`);
                const ageEl   = document.getElementById(`pax${i}Age`);
                const sexEl   = document.getElementById(`pax${i}Sex`);

                if (nameEl && !nameEl.value.trim()) {
                    nameEl.classList.add('error');
                    document.getElementById(`pax${i}NameError`)?.classList.add('visible');
                    valid = false;
                } else if (nameEl) {
                    nameEl.classList.remove('error');
                    document.getElementById(`pax${i}NameError`)?.classList.remove('visible');
                }

                if (ageEl && (!ageEl.value || ageEl.value < 1)) {
                    ageEl.classList.add('error');
                    document.getElementById(`pax${i}AgeError`)?.classList.add('visible');
                    valid = false;
                } else if (ageEl) {
                    ageEl.classList.remove('error');
                    document.getElementById(`pax${i}AgeError`)?.classList.remove('visible');
                }

                if (sexEl && !sexEl.value) {
                    sexEl.classList.add('error');
                    document.getElementById(`pax${i}SexError`)?.classList.add('visible');
                    valid = false;
                } else if (sexEl) {
                    sexEl.classList.remove('error');
                    document.getElementById(`pax${i}SexError`)?.classList.remove('visible');
                }
            }

            // 5. Payment method
            const payment = document.getElementById('paymentInput').value;
            if (!payment) {
                document.getElementById('paymentError').classList.add('visible');
                valid = false;
            } else {
                document.getElementById('paymentError').classList.remove('visible');
            }

            // If all valid — populate the review modal and open it
            if (valid) {
                populateReviewModal(count);
                const modal = new bootstrap.Modal(document.getElementById('reviewModal'));
                modal.show();
            } else {
                // Scroll to first visible error so user can see what's missing
                const firstError = document.querySelector('.field-error.visible, .acc-option.error-border');
                if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        // ---- Populate review modal with current form values ----
        function populateReviewModal(count) {
            document.getElementById('reviewAccommodation').textContent =
                document.getElementById('accommodationInput').value;

            document.getElementById('reviewContact').textContent =
                document.getElementById('contactNumber').value;

            document.getElementById('reviewPaxCount').textContent =
                count + ' passenger(s)';

            document.getElementById('reviewPayment').textContent =
                document.getElementById('paymentInput').value;

            // Build passenger list
            let paxHtml = '<strong style="color:#03396c; font-size:0.88rem;">Passengers</strong>';
            for (let i = 0; i < count; i++) {
                const name = document.getElementById(`pax${i}Name`)?.value || '—';
                const age  = document.getElementById(`pax${i}Age`)?.value  || '—';
                const sex  = document.getElementById(`pax${i}Sex`)?.value  || '—';
                paxHtml += `
                    <div class="review-row mt-1">
                        <span class="r-label">Passenger ${i + 1}</span>
                        <span class="r-value">${name}, ${age} yrs, ${sex}</span>
                    </div>`;
            }
            document.getElementById('reviewPassengerList').innerHTML = paxHtml;
        }

        // ---- Clear error state when user starts typing/selecting ----
        document.getElementById('contactNumber').addEventListener('input', function() {
            this.classList.remove('error');
            document.getElementById('contactError').classList.remove('visible');
        });

    </script>
}
