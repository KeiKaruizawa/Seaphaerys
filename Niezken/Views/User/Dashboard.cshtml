@* ============================================================
   Dashboard.cshtml
   📁 Location: Views/User/Dashboard.cshtml
   🔁 Action: REPLACE the existing file

   The passenger's personal dashboard. Shows:
     - Welcome message with their name
     - List of all their bookings
     - Cancel button for active bookings
     - Reschedule button for active bookings
   ============================================================ *@

@model Niezken.Models.User

@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_Layout"; @* Previously missing — this adds the navbar and footer *@
}

<style>
    /* Page heading */
    .page-title {
        color: #0077b6;
        font-weight: 700;
        margin-top: 40px;
        margin-bottom: 4px;
    }

    /* Stats cards row at the top */
    .stat-card {
        background: white;
        border-radius: 15px;
        padding: 20px 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.07);
        text-align: center;
        transition: 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-4px);
        }

        .stat-card .stat-number {
            font-size: 2rem;
            font-weight: 800;
            color: #03396c;
        }

        .stat-card .stat-label {
            color: #888;
            font-size: 0.88rem;
            margin-top: 2px;
        }

    /* Bookings table card */
    .table-card {
        background: white;
        border-radius: 15px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.07);
        margin-top: 30px;
    }

        .table-card h5 {
            color: #03396c;
            font-weight: 700;
            margin-bottom: 18px;
        }

    /* Table header — dark blue matching site */
    .table thead {
        background-color: #03396c;
        color: white;
    }

        .table thead th {
            font-weight: 600;
            font-size: 0.88rem;
            border: none;
            padding: 12px 14px;
        }

    .table tbody tr {
        font-size: 0.9rem;
        color: #03396c;
        vertical-align: middle;
    }

        .table tbody tr:hover {
            background: #f0f8ff;
        }

    /* Status badges */
    .badge-booked {
        background: #d1f5ea;
        color: #1a7a56;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .badge-cancelled {
        background: #fde8e8;
        color: #c1121f;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .badge-rescheduled {
        background: #fff3cd;
        color: #856404;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    /* Action buttons inside the table */
    .btn-cancel {
        background: white;
        color: #c1121f;
        border: 1.5px solid #c1121f;
        border-radius: 8px;
        padding: 4px 12px;
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s;
        display: inline-block;
    }

        .btn-cancel:hover {
            background: #c1121f;
            color: white;
        }

    /* Reschedule modal trigger button */
    .btn-reschedule {
        background: white;
        color: #0077b6;
        border: 1.5px solid #0077b6;
        border-radius: 8px;
        padding: 4px 12px;
        font-size: 0.82rem;
        font-weight: 600;
        transition: 0.2s;
        cursor: pointer;
    }

        .btn-reschedule:hover {
            background: #0077b6;
            color: white;
        }

    /* Empty state message */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #888;
    }

    /* Book Now CTA button */
    .btn-booknow {
        background-color: #03396c;
        color: white;
        border: 1.5px solid #03396c;
        border-radius: 10px;
        padding: 10px 28px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
        display: inline-block;
        margin-top: 14px;
    }

        .btn-booknow:hover {
            background-color: white;
            color: #03396c;
        }
</style>

@* ---- WELCOME HEADER ---- *@
<h2 class="page-title">My Dashboard</h2>
<p class="text-muted mb-4">Welcome back, <strong>@Model.FirstName @Model.LastName</strong>!</p>

@* ---- STATS CARDS ---- *@
<div class="row g-3 mb-2">

    @* Count all bookings *@
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-number">@Model.Bookings.Count</div>
            <div class="stat-label">Total Bookings</div>
        </div>
    </div>

    @* Count only active (Booked or Rescheduled) bookings *@
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-number">
                @Model.Bookings.Count(b => b.Status == "Booked" || b.Status == "Rescheduled")
            </div>
            <div class="stat-label">Active Bookings</div>
        </div>
    </div>

    @* Count only cancelled bookings *@
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-number">
                @Model.Bookings.Count(b => b.Status == "Cancelled")
            </div>
            <div class="stat-label">Cancelled</div>
        </div>
    </div>

</div>

@* ---- BOOKINGS TABLE ---- *@
<div class="table-card">
    <h5>My Bookings</h5>

    @if (!Model.Bookings.Any())
    {
        @* No bookings yet — show a prompt to book *@
        <div class="empty-state">
            <p class="mb-0">You have no bookings yet.</p>
            <a asp-controller="Booking" asp-action="BookNow" class="btn-booknow">
                Book a Trip Now
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Ship</th>
                        <th>Route</th>
                        <th>Travel Date</th>
                        <th>Accommodation</th>
                        <th>Passengers</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Bookings.OrderByDescending(b => b.TravelDate))
                    {
                        <tr>
                            <td><strong>@booking.ShipName</strong></td>
                            <td>@booking.Route</td>
                            <td>@booking.TravelDate.ToString("MMM dd, yyyy")</td>
                            <td>@booking.AccommodationType</td>
                            <td>@booking.PassengerCount pax</td>

                            @* Status badge — color depends on status value *@
                            <td>
                                @if (booking.Status == "Booked")
                                {
                                    <span class="badge-booked">Booked</span>
                                }
                                else if (booking.Status == "Rescheduled")
                                {
                                    <span class="badge-rescheduled">Rescheduled</span>
                                }
                                else
                                {
                                    <span class="badge-cancelled">Cancelled</span>
                                }
                            </td>

                            @* Action buttons — only shown for active bookings *@
                            <td>
                                @if (booking.Status == "Cancelled")
                                {
                                    <span class="text-muted small">—</span>
                                }
                                else
                                {
                                    @* Cancel booking — asks for confirmation first *@
                                    <a asp-controller="Booking"
                                       asp-action="Cancel"
                                       asp-route-id="@booking.Id"
                                       class="btn-cancel me-1"
                                       onclick="return confirm('Cancel this booking?')">
                                        Cancel
                                    </a>

                                    @* Reschedule button — opens the reschedule modal *@
                                    <button class="btn-reschedule"
                                            onclick="openReschedule(@booking.Id)">
                                        Reschedule
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ============================================================
   RESCHEDULE MODAL
   Hidden by default. Opens when "Reschedule" button is clicked.
   Submits to UserController.Reschedule via POST.
   ============================================================ *@
<div class="modal fade" id="rescheduleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:15px;">

            <div class="modal-header" style="border-bottom: 2px solid #e3f2fd;">
                <h5 class="modal-title fw-bold" style="color:#03396c;">Reschedule Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            @* Form submits to User/Reschedule with the booking ID and new date *@
            <form asp-controller="User" asp-action="Reschedule" method="post">
                <div class="modal-body">

                    @* Hidden field — stores which booking is being rescheduled *@
                    <input type="hidden" name="id" id="rescheduleBookingId" />

                    <label class="form-label fw-bold" style="color:#03396c;">Select New Travel Date</label>
                    <input type="date"
                           name="newDate"
                           class="form-control"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")"
                           required />

                </div>
                <div class="modal-footer" style="border-top: 2px solid #e3f2fd;">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal"
                            style="border-radius:8px;">
                        Cancel
                    </button>
                    <button type="submit"
                            class="btn"
                            style="background:#03396c; color:white; border-radius:8px; font-weight:600;">
                        Confirm Reschedule
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Opens the reschedule modal and sets the booking ID
        // so the form knows which booking to reschedule
        function openReschedule(bookingId) {
            document.getElementById('rescheduleBookingId').value = bookingId;
            const modal = new bootstrap.Modal(document.getElementById('rescheduleModal'));
            modal.show();
        }
    </script>
}
