@model Niezken.Models.User
@using Niezken.Models

@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_Layout";
}

<style>
    .page-title {
        color: #0077b6;
        font-weight: 700;
        margin-top: 40px;
        margin-bottom: 4px;
    }

    /* Stats cards */
    .stat-card {
        background: white;
        border-radius: 15px;
        padding: 20px 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.07);
        text-align: center;
        transition: 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-4px);
        }

    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: #03396c;
    }

    .stat-label {
        color: #888;
        font-size: 0.88rem;
        margin-top: 2px;
    }

    /* Bookings table card */
    .table-card {
        background: white;
        border-radius: 15px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.07);
        margin-top: 30px;
    }

        .table-card h5 {
            color: #03396c;
            font-weight: 700;
            margin-bottom: 18px;
        }

    /* Table header */
    .table thead {
        background-color: #03396c;
        color: white;
    }

        .table thead th {
            font-weight: 600;
            font-size: 0.88rem;
            border: none;
            padding: 12px 14px;
        }

    /* Clickable rows */
    .table tbody tr {
        font-size: 0.9rem;
        color: #03396c;
        vertical-align: middle;
        cursor: pointer; /* Shows hand cursor to indicate clickable */
        transition: 0.15s;
    }

        .table tbody tr:hover {
            background: #f0f8ff;
        }

    /* Hint text under table */
    .click-hint {
        color: #aaa;
        font-size: 0.8rem;
        margin-top: 8px;
        text-align: center;
    }

    /* Status badges — only 2 colors: blue for active, grey for cancelled */
    .badge-active {
        background: #e3f2fd;
        color: #0077b6;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 0.8rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .badge-cancelled {
        background: #f0f0f0;
        color: #888;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #888;
    }

    .btn-booknow {
        background-color: #03396c;
        color: white;
        border: 1.5px solid #03396c;
        border-radius: 10px;
        padding: 10px 28px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
        display: inline-block;
        margin-top: 14px;
    }

        .btn-booknow:hover {
            background-color: white;
            color: #03396c;
        }

    /* ---- Details Modal ---- */
    .modal-content {
        border-radius: 15px;
        border: none;
    }

    .modal-header {
        border-bottom: 2px solid #e3f2fd;
        padding: 18px 24px;
    }

    .modal-title {
        color: #03396c;
        font-weight: 700;
    }

    .modal-body {
        padding: 20px 24px;
    }

    .modal-footer {
        border-top: 2px solid #e3f2fd;
        padding: 14px 24px;
    }

    /* Detail rows inside modal */
    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 7px 0;
        border-bottom: 1px solid #f0f8ff;
        font-size: 0.9rem;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-row .d-label {
            color: #888;
            font-weight: 500;
        }

        .detail-row .d-value {
            font-weight: 600;
            color: #03396c;
            text-align: right;
        }

    /* Section inside modal */
    .modal-section {
        background: #f8fbff;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 14px;
    }

    .modal-section-title {
        font-size: 0.78rem;
        font-weight: 700;
        color: #0077b6;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
    }

    /* Passenger list inside modal */
    .pax-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        border-bottom: 1px solid #eef5fb;
        font-size: 0.88rem;
    }

        .pax-item:last-child {
            border-bottom: none;
        }

    .pax-num {
        background: #03396c;
        color: white;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    /* Modal action buttons — consistent style */
    .btn-modal-cancel {
        background: white;
        color: #c1121f;
        border: 1.5px solid #c1121f;
        border-radius: 8px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.88rem;
        transition: 0.2s;
        cursor: pointer;
    }

        .btn-modal-cancel:hover {
            background: #c1121f;
            color: white;
        }

    .btn-modal-reschedule {
        background: #03396c;
        color: white;
        border: 1.5px solid #03396c;
        border-radius: 8px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.88rem;
        transition: 0.2s;
        cursor: pointer;
    }

        .btn-modal-reschedule:hover {
            background: white;
            color: #03396c;
        }

    /* Reschedule date input inside modal */
    .reschedule-section {
        display: none; /* Hidden until Reschedule button is clicked */
        margin-top: 14px;
        background: #f0f8ff;
        border-radius: 10px;
        padding: 14px 16px;
    }

        .reschedule-section.visible {
            display: block;
        }

    .form-control-sm {
        border: 1.5px solid #d0e8f5;
        border-radius: 8px;
        padding: 8px 12px;
        color: #03396c;
        font-size: 0.9rem;
    }

        .form-control-sm:focus {
            border-color: #0077b6;
            box-shadow: 0 0 0 3px rgba(0,119,182,0.1);
            outline: none;
        }
</style>

@* ---- WELCOME ---- *@
<h2 class="page-title">My Dashboard</h2>
<p class="text-muted mb-4">
    Welcome back, <strong>@Model.FirstName @Model.LastName</strong>!
</p>

@* ---- STATS CARDS ---- *@
<div class="row g-3 mb-2">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-number">@Model.Bookings.Count</div>
            <div class="stat-label">Total Bookings</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-number">
                @Model.Bookings.Count(b => b.Status != "Cancelled")
            </div>
            <div class="stat-label">Active Bookings</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-number">
                @Model.Bookings.Count(b => b.Status == "Cancelled")
            </div>
            <div class="stat-label">Cancelled</div>
        </div>
    </div>
</div>

@* ---- BOOKINGS TABLE ---- *@
<div class="table-card">
    <h5>My Bookings</h5>

    @if (!Model.Bookings.Any())
    {
        <div class="empty-state">
            <p class="mb-0">You have no bookings yet.</p>
            <a asp-controller="Booking" asp-action="BookNow" class="btn-booknow">
                Book a Trip Now
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Ship</th>
                        <th>Route</th>
                        <th>Travel Date</th>
                        <th>Departure</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Bookings.OrderByDescending(b => b.TravelDate))
                    {
                        @* Each row is clickable — opens the details modal *@
                        @* Data stored as attributes — avoids JS breaking on
                           special characters like apostrophes or dashes *@
                        <tr class="booking-row"
                            data-id="@booking.Id"
                            data-ship="@booking.ShipName"
                            data-route="@booking.Route"
                            data-date="@booking.TravelDate.ToString("MMMM dd, yyyy")"
                            data-departure="@(booking.DepartureTime ?? "—")"
                            data-accommodation="@(booking.AccommodationType ?? "—")"
                            data-paxcount="@booking.PassengerCount"
                            data-contact="@(booking.ContactNumber ?? "—")"
                            data-payment="@(booking.PaymentMethod ?? "—")"
                            data-status="@booking.Status"
                            data-passengers="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(booking.PassengersJson ?? "[]"))">
                            <td><strong>@booking.ShipName</strong></td>
                            <td>@booking.Route</td>
                            <td>@booking.TravelDate.ToString("MMM dd, yyyy")</td>
                            <td>@(booking.DepartureTime ?? "—")</td>
                            <td>
                                @if (booking.Status == "Cancelled")
                                {
                                    <span class="badge-cancelled">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge-active">@booking.Status</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Hint to tell user the rows are clickable *@
        <p class="click-hint">Click any booking to view details</p>
    }
</div>

@* ============================================================
   BOOKING DETAILS MODAL
   Opened when user clicks a booking row.
   Shows full info + Cancel & Reschedule buttons.
   Cancel shows a confirmation before proceeding.
   ============================================================ *@
<div class="modal fade" id="bookingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="modalShipName">Booking Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                @* Trip details section *@
                <div class="modal-section">
                    <div class="modal-section-title">Trip Details</div>
                    <div class="detail-row">
                        <span class="d-label">Route</span>
                        <span class="d-value" id="modalRoute">—</span>
                    </div>
                    <div class="detail-row">
                        <span class="d-label">Travel Date</span>
                        <span class="d-value" id="modalDate">—</span>
                    </div>
                    <div class="detail-row">
                        <span class="d-label">Departure Time</span>
                        <span class="d-value" id="modalDeparture">—</span>
                    </div>
                    <div class="detail-row">
                        <span class="d-label">Accommodation</span>
                        <span class="d-value" id="modalAccommodation">—</span>
                    </div>
                    <div class="detail-row">
                        <span class="d-label">Status</span>
                        <span class="d-value" id="modalStatus">—</span>
                    </div>
                </div>

                @* Contact & payment section *@
                <div class="modal-section">
                    <div class="modal-section-title">Contact & Payment</div>
                    <div class="detail-row">
                        <span class="d-label">Passengers</span>
                        <span class="d-value" id="modalPaxCount">—</span>
                    </div>
                    <div class="detail-row">
                        <span class="d-label">Contact Number</span>
                        <span class="d-value" id="modalContact">—</span>
                    </div>
                    <div class="detail-row">
                        <span class="d-label">Payment Method</span>
                        <span class="d-value" id="modalPayment">—</span>
                    </div>
                </div>

                @* Passenger list section — filled by JS *@
                <div class="modal-section" id="modalPaxSection" style="display:none;">
                    <div class="modal-section-title">Passengers</div>
                    <div id="modalPaxList"></div>
                </div>

                @* Reschedule date picker — hidden until Reschedule clicked *@
                <div class="reschedule-section" id="rescheduleSection">
                    <div class="modal-section-title mb-2">Select New Travel Date</div>
                    <input type="date"
                           id="newDateInput"
                           class="form-control-sm w-100"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                    <div class="d-flex gap-2 mt-3">
                        <button type="button"
                                class="btn-modal-reschedule"
                                onclick="confirmReschedule()">
                            Confirm Reschedule
                        </button>
                        <button type="button"
                                class="btn btn-secondary btn-sm"
                                onclick="hideReschedule()"
                                style="border-radius:8px;">
                            Back
                        </button>
                    </div>
                </div>

            </div>

            @* Modal footer — action buttons, hidden for cancelled bookings *@
            <div class="modal-footer" id="modalActions">
                <button type="button"
                        class="btn-modal-cancel"
                        id="cancelBtn"
                        onclick="confirmCancel()">
                    Cancel Booking
                </button>
                <button type="button"
                        class="btn-modal-reschedule"
                        id="rescheduleBtn"
                        onclick="showReschedule()">
                    Reschedule
                </button>
            </div>

        </div>
    </div>
</div>

@* Hidden forms for cancel and reschedule — submitted by JS *@
<form id="cancelForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<form id="rescheduleForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="newDate" id="rescheduleNewDate" />
</form>

@section Scripts {
    <script>
        // Stores the current booking ID being viewed
        let currentBookingId = null;

        // Attach click handler to all booking rows via event delegation
        // This reads data from data-* attributes — safe from special characters
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.booking-row').forEach(function (row) {
                row.addEventListener('click', function () {
                    // Read all booking data from the row's data attributes
                    const id            = row.dataset.id;
                    const ship          = row.dataset.ship;
                    const route         = row.dataset.route;
                    const date          = row.dataset.date;
                    const departure     = row.dataset.departure;
                    const accommodation = row.dataset.accommodation;
                    const paxCount      = row.dataset.paxcount;
                    const contact       = row.dataset.contact;
                    const payment       = row.dataset.payment;
                    const status        = row.dataset.status;
                    const passengersJson = row.dataset.passengers;

                    openBookingModal(id, ship, route, date, departure,
                                     accommodation, paxCount, contact,
                                     payment, status, passengersJson);
                });
            });
        });

        // Opens the booking details modal with the provided data
        function openBookingModal(id, ship, route, date, departure,
                                  accommodation, paxCount, contact,
                                  payment, status, passengersJson) {
            currentBookingId = id;

            // Populate modal fields
            document.getElementById('modalShipName').textContent     = ship;
            document.getElementById('modalRoute').textContent        = route;
            document.getElementById('modalDate').textContent         = date;
            document.getElementById('modalDeparture').textContent    = departure;
            document.getElementById('modalAccommodation').textContent = accommodation;
            document.getElementById('modalStatus').textContent       = status;
            document.getElementById('modalPaxCount').textContent     = paxCount + ' passenger(s)';
            document.getElementById('modalContact').textContent      = contact;
            document.getElementById('modalPayment').textContent      = payment;

            // Parse and display the passenger list
            try {
                const passengers = JSON.parse(passengersJson);
                const paxSection = document.getElementById('modalPaxSection');
                const paxList    = document.getElementById('modalPaxList');

                if (passengers && passengers.length > 0) {
                    paxList.innerHTML = passengers.map((p, i) => `
                        <div class="pax-item">
                            <div class="pax-num">${i + 1}</div>
                            <div>
                                <strong>${p.FullName || '—'}</strong>
                                <span class="text-muted ms-2" style="font-size:0.82rem;">
                                    ${p.Age || '—'} yrs &bull; ${p.Sex || '—'}
                                </span>
                            </div>
                        </div>`).join('');
                    paxSection.style.display = 'block';
                } else {
                    paxSection.style.display = 'none';
                }
            } catch (e) {
                // If JSON parse fails, just hide the passenger section
                document.getElementById('modalPaxSection').style.display = 'none';
            }

            // Reset reschedule section
            hideReschedule();

            // Hide action buttons for cancelled bookings
            const actions = document.getElementById('modalActions');
            actions.style.display = (status === 'Cancelled') ? 'none' : 'flex';

            // Open the Bootstrap modal
            const modal = new bootstrap.Modal(document.getElementById('bookingModal'));
            modal.show();
        }

        // Shows a browser confirmation before cancelling
        // Only proceeds if user clicks OK
        function confirmCancel() {
            if (confirm('Are you sure you want to cancel this booking? This cannot be undone.')) {
                // Submit to Booking/Cancel with the booking ID
                const form   = document.getElementById('cancelForm');
                form.action  = '/Booking/Cancel/' + currentBookingId;
                form.submit();
            }
        }

        // Shows the reschedule date picker inside the modal
        function showReschedule() {
            document.getElementById('rescheduleSection').classList.add('visible');
            // Hide the main action buttons while reschedule is open
            document.getElementById('cancelBtn').style.display    = 'none';
            document.getElementById('rescheduleBtn').style.display = 'none';
        }

        // Hides the reschedule section and shows buttons again
        function hideReschedule() {
            document.getElementById('rescheduleSection').classList.remove('visible');
            document.getElementById('cancelBtn').style.display    = '';
            document.getElementById('rescheduleBtn').style.display = '';
        }

        // Submits the reschedule form after date is picked
        function confirmReschedule() {
            const newDate = document.getElementById('newDateInput').value;

            if (!newDate) {
                alert('Please select a new travel date.');
                return;
            }

            // Confirm before submitting
            if (confirm('Reschedule this booking to ' + newDate + '?')) {
                const form    = document.getElementById('rescheduleForm');
                form.action   = '/User/Reschedule/' + currentBookingId;
                document.getElementById('rescheduleNewDate').value = newDate;
                form.submit();
            }
        }
    </script>
}
