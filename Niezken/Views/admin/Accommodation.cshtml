@model IEnumerable<Niezken.Models.Ship>

@{
    ViewData["Title"] = "Accommodation Management";
    Layout = "_AdminLayout";
}

<style>
    .page-title {
        font-weight: 700;
        color: #0077b6;
    }

    .ship-img {
        width: 70px;
        height: 50px;
        object-fit: cover;
        border-radius: 6px;
    }

    .table-container {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .btn-action {
        min-width: 70px;
    }
</style>

<div class="container mt-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="page-title">
            <i class="fa fa-ship"></i> Accommodation Management
        </h2>

        <a asp-controller="Admin"
           asp-action="CreateShip"
           class="btn btn-success">

            <i class="fa fa-plus"></i> Add Accommodation
        </a>
    </div>

    <!-- SEARCH BAR -->
    <div class="row mb-3">
        <div class="col-md-4">
            <form asp-action="SearchShip" method="get">
                <div class="input-group">
                    <input type="text"
                           name="query"
                           class="form-control"
                           placeholder="Search ship or route..." />

                    <button class="btn btn-primary">
                        <i class="fa fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- TABLE -->
    <div class="table-container">

        <table class="table table-striped table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Ship Name</th>
                    <th>Route</th>
                    <th>Price</th>
                    <th width="220">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            No accommodations available.
                        </td>
                    </tr>
                }

                @foreach (var ship in Model)
                {
                    <tr>

                        <td>
                            <img src="~/images/@ship.Image"
                                 class="ship-img"
                                 alt="@ship.Name" />
                        </td>

                        <td>
                            <strong>@ship.Name</strong>
                        </td>

                        <td>@ship.Route</td>

                        <td class="text-success fw-bold">
                            @ship.Price
                        </td>

                        <td>

                            <a asp-action="EditShip"
                               asp-route-id="@ship.Id"
                               class="btn btn-warning btn-sm btn-action">

                                <i class="fa fa-edit"></i> Edit
                            </a>

                            <a asp-action="DeleteShip"
                               asp-route-id="@ship.Id"
                               class="btn btn-danger btn-sm btn-action"
                               onclick="return confirm('Are you sure you want to delete this accommodation?');">

                                <i class="fa fa-trash"></i> Delete
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>